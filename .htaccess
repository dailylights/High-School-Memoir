# 安全头配置
<IfModule mod_headers.c>
    # 防止点击劫持
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # 防止 MIME 类型嗅探
    Header always set X-Content-Type-Options "nosniff"
    
    # XSS 保护
    Header always set X-XSS-Protection "1; mode=block"
    
    # 引用策略
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # 内容安全策略
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; media-src 'self'; frame-ancestors 'self';"
    
    # 严格传输安全（HTTPS 环境下启用）
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# 禁止目录列表
Options -Indexes

# 禁止访问敏感文件
<FilesMatch "\.(env|sql|md|json|bak|old)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# 禁止访问 .htaccess 等配置文件
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# PHP 安全配置
<IfModule mod_php7.c>
    php_flag expose_php Off
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
